# ==========================================================
# PYTHON
# ==========================================================
_pycache_/
*.py[cod]
*.pyo
*.pyd

# Ambiente virtual
venv/
.env/
.env.*
.venv/

# ==========================================================
# IDE / EDITOR
# ==========================================================
.vscode/
.idea/
*.swp
*.swo

# MacOS
.DS_Store

# ==========================================================
# JUPYTER
# ==========================================================
.ipynb_checkpoints/

# ==========================================================
# LOGS
# ==========================================================
*.log

# ==========================================================
# DATA (CUIDADO COM DADOS REAIS)
# ==========================================================

# Ignora dados brutos sensíveis
data/raw/*
!data/raw/.gitkeep

# Ignora dados intermediários
data/canonical/*
!data/canonical/.gitkeep

# Ignora outputs gerados
data/outputs/*
!data/outputs/.gitkeep

# ==========================================================
# EXPORTS / ARTEFATOS
# ==========================================================
*.csv
*.xlsx
*.json
*.png
*.jpg
*.html

# (opcional) manter exemplos versionados
!docs/examples/*.json

# ==========================================================
# TESTES / TEMP
# ==========================================================
tmp/
temp/
*.tmp

# ==========================================================
# SISTEMA
# ==========================================================
Thumbs.db